{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/kanban/",
	"preferredVersions": {
		"wp": "latest",
		"php": "8.4"
	},
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/mkwpde/wp-kanban/archive/refs/heads/main.zip"
			}
		},
		{
			"step": "activatePlugin",
			"pluginPath": "wp-kanban-main/plugin.php"
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_column",
				"body": "name=To+Do"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_column",
				"body": "name=In+Progress"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_column",
				"body": "name=Done"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_tasks",
				"body": "title=Design+landing+page&status=publish&kanban_column=1"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_tasks",
				"body": "title=Set+up+development+environment&status=publish&kanban_column=1"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_tasks",
				"body": "title=Create+wireframes&status=publish&kanban_column=1"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_tasks",
				"body": "title=Implement+user+authentication&status=publish&kanban_column=2"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_tasks",
				"body": "title=Project+kickoff+meeting&status=publish&kanban_column=3"
			}
		},
		{
			"step": "request",
			"request": {
				"method": "POST",
				"url": "/wp-json/wp/v2/kanban_tasks",
				"body": "title=Requirements+gathering&status=publish&kanban_column=3"
			}
		},
		{
			"step": "wp-cli",
			"command": "wp post create --post_type=page --post_title='Kanban Board' --post_name='kanban' --post_content='<!-- wp:mkwpde/kanban-board /-->' --post_status=publish"
		}
	]
}